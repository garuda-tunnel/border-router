{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["namespace", "name", "images", "mtuPolicy"],
  "properties": {
    "namespace": { "type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
    "name":      { "type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
    "images": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "border": { "type": "string" },
        "frr":    { "type": "string" }
      }
    },
    "frr-sidecar": { "type": "object" },
    "ospf": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["router_id"],
      "properties": {
        "router_id": { "type": "string" }
      }
    },
    "mtuPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixedMss", "mssClampEnabled"],
      "properties": {
        "fixedMss":        { "type": "integer", "minimum": 536, "maximum": 1460 },
        "mssClampEnabled": { "type": "boolean" }
      }
    }
  }
}
